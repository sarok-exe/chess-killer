{
  "manifest_version": 3,
  "name": "Chess Killer",
  "version": "2.0.0",
  "description": "Chess analyzer with Stockfish for Chess.com - supports algebraic notation",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://*.chess.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [{
    "matches": ["https://*.chess.com/*"],
    "js": ["content.js"],
    "run_at": "document_end"
  }],
  "web_accessible_resources": [{
    "resources": ["stockfish.js", "stockfish.wasm"],
    "matches": ["https://*.chess.com/*"]
  }]
}
